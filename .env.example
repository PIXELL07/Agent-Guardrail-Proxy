# Copy this to .env and fill in real values before deploying.

# "development" (default) or "production". In production, the backend
# refuses to start with CORS_ORIGINS=* (see below).
ENVIRONMENT=development
ALLOW_WILDCARD_CORS_IN_PRODUCTION=false

# Domain for automatic TLS via Caddy (docker-compose.prod.yml only).
DOMAIN=localhost

# Comma-separated master API keys accepted by the proxy. These can also
# issue/revoke individual keys via POST /v1/admin/keys -- see README.
# Generate real random values for production, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=dev-local-key

# Rate limiting (per agent_id)
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Max request body size in bytes (protects the detection tiers from
# CPU/memory exhaustion via oversized payloads)
MAX_REQUEST_BODY_BYTES=2000000

# Judge model backend: "ollama" (local, free) or "openai" (hosted, costs money)
JUDGE_BACKEND=ollama
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3.2
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Detection thresholds (tune based on observed traffic -- see README for
# the real false-positive/false-negative bugs found during testing)
SIMILARITY_THRESHOLD=0.3
CLASSIFIER_THRESHOLD=0.5
AMBIGUOUS_LOW=0.35
AMBIGUOUS_HIGH=0.6

# Storage
DB_PATH=guardrail.db

# CORS -- comma-separated origins, or "*" for all (dev only)
CORS_ORIGINS=*
